# Copy to .env and fill in local values. Never commit .env.

# Production can use host environment variables instead of a .env file.



MONGODB_URI=mongodb://localhost:27017/signpack

APP_DOMAIN=http://localhost:8090



SMTP_HOST=smtp.example.com

SMTP_PORT=587

SMTP_USER=your-smtp-user

SMTP_PASS=your-smtp-password

# Send-as / From header (must be allowed by your mail provider)

SMTP_FROM="TC Signpack Maker <no-reply@example.com>"



DISCORD_CLIENT_ID=your-discord-client-id

DISCORD_CLIENT_SECRET=your-discord-client-secret



# Support address shown in transactional emails

SUPPORT_EMAIL=support@example.com

SESSION_SECRET=change-me-to-a-long-random-string

PORT=8090



# Optional Ram AI helper (editor /signpack — not required for normal use)

RAM_AI_ENABLED=false

RAM_AI_BASE_URL=https://ai.rambot.xyz

RAM_AI_API_KEY=replace-me

# Default model label in the helper UI (must match a known display name)
RAM_AI_DEFAULT_MODEL=Ram AI Code Agent 1.0 - fast

# Optional comma-separated allowlist of display names (dropdown only; no free text)
# RAM_AI_ALLOWED_MODELS=Ram AI Code Agent 1.0 - fast,Ram AI Code Agent 1.0,Ram AI Chat

# Optional legacy: direct upstream model id for default (server-only; overrides label resolution)
# RAM_AI_MODEL=ram-ai-7b

# 0 disables normal request timeout while stream/status remains alive.
RAM_AI_TIMEOUT_MS=0

RAM_AI_STATUS_POLL_MS=5000

# Server cache for GET /api/ram-ai/status (ms) — avoids calling Ram AI every poll
RAM_AI_STATUS_CACHE_MS=5000

# Per-session max status requests per RAM_AI_RATE_LIMIT_WINDOW_MS (separate from helper POST limit)
RAM_AI_STATUS_RATE_LIMIT_MAX=45

# Per signed-in session (or IP fallback): max requests per window

RAM_AI_RATE_LIMIT_MAX=20

RAM_AI_RATE_LIMIT_WINDOW_MS=60000

# Safe parsing logs only (status, content-type, keys, text length — no secrets)
RAM_AI_DEBUG=false

# WebAuthn / Passkeys
WEBAUTHN_RP_NAME=Signpack Maker
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:8090

# Set to true to log auth redirects and /login access (debug only)
AUTH_DEBUG=false


