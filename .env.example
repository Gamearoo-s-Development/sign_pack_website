# Copy to .env and fill in local values. Never commit .env.
# Production can use host environment variables instead of a .env file.

MONGODB_URI=mongodb://localhost:27017/signpack
APP_DOMAIN=http://localhost:8090

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password

DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret

# Optional (not wired in app.js yet; for future use)
SESSION_SECRET=change-me-to-a-long-random-string
PORT=8090
