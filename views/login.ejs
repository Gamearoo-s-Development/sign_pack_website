<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>TC Signpack Maker | Login</title>
  <link rel="icon" type="image/png" href="https://gamearoo.top/ram-api-img/bc91c29e-d0af-460f-a30e-541cd5b57179.png" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <style>
    body {
      background: linear-gradient(to bottom right, #111, #222);
      color: #fff;
      font-family: 'Segoe UI', sans-serif;
      display: flex;
      align-items: center;
      justify-content: center;
      height: 100vh;
      margin: 0;
    }

    .login-box {
      background: rgba(0, 0, 0, 0.6);
      border: 1px solid rgba(255, 255, 255, 0.08);
      backdrop-filter: blur(10px);
      padding: 40px;
      border-radius: 15px;
      box-shadow: 0 0 20px rgba(255, 165, 0, 0.2);
      width: 100%;
      max-width: 400px;
    }

    .form-control {
      background-color: #1f1f1f;
      border: 1px solid #444;
      color: #fff;
    }

    .form-control:focus {
      border-color: #ffa500;
      box-shadow: 0 0 0 0.25rem rgba(255, 165, 0, 0.25);
    }

    .btn-orange {
      background-color: #ffa500;
      color: #000;
      border: none;
    }

    .btn-orange:hover {
      background-color: #ffb733;
    }

    a {
      color: #ccc;
      text-decoration: none;
    }

    a:hover {
      color: #ffa500;
    }

    .logo {
      display: block;
      margin: 0 auto 20px;
      max-width: 100px;
      border-radius: 12px;
      box-shadow: 0 0 12px rgba(255, 165, 0, 0.4);
    }
  </style>
</head>
<body>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

  <div class="login-box text-center">
    <img src="https://gamearoo.top/ram-api-img/bc91c29e-d0af-460f-a30e-541cd5b57179.png" alt="Logo" class="logo" />
    <h2 class="mb-4">Signpack Maker Login</h2>
    <form action="/login" method="POST">
      <div class="mb-3 text-start">
        <label for="email" class="form-label">Email Address</label>
        <input type="email" id="email" name="email" class="form-control" required />
      </div>

      <div class="mb-4 text-start">
        <label for="pass" class="form-label">Password</label>
        <input type="password" id="pass" name="pass" class="form-control" required />
      </div>

      <button type="submit" class="btn btn-orange w-100 fw-bold">Login</button>
    </form>
    <!-- <div class="text-center mt-4">
        <a href="/auth/discord" class="btn btn-dark w-100 fw-bold" style="background-color: #5865F2; color: white;">
          <i class="fab fa-discord me-2"></i> Login with Discord
        </a>
      </div> -->

    <div class="text-center mt-3">
      <small>Don't have an account? <a href="/signup">Sign up</a></small>
      
    </div>
     <div class="text-center mt-3">
<small>Forgot Password? <a href="/forgot-password">Forgot Password</a></small>
     </div>
  </div>

</body>
</html>
