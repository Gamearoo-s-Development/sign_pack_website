<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>TC Signpack Maker | Signup</title>
  <link rel="icon" type="image/png" href="https://gamearoo.top/ram-api-img/bc91c29e-d0af-460f-a30e-541cd5b57179.png" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <style>
   body {
  background: linear-gradient(to bottom right, #111, #222);
  color: #fff;
  font-family: 'Segoe UI', sans-serif;
  margin: 0;
  padding: 0;
  min-height: 100vh;
  overflow-x: hidden;
}


    .signup-box {
      background: rgba(0, 0, 0, 0.6);
      border: 1px solid rgba(255, 255, 255, 0.08);
      backdrop-filter: blur(10px);
      padding: 40px;
      border-radius: 15px;
      box-shadow: 0 0 20px rgba(255, 165, 0, 0.2);
      width: 100%;
      max-width: 450px;
    }

    .form-control {
      background-color: #1f1f1f;
      border: 1px solid #444;
      color: #fff;
    }

    .form-control:focus {
      border-color: #ffa500;
      box-shadow: 0 0 0 0.25rem rgba(255, 165, 0, 0.25);
    }

    .btn-orange {
      background-color: #ffa500;
      color: #000;
      border: none;
    }

    .btn-orange:hover {
      background-color: #ffb733;
    }

    a {
      color: #ccc;
      text-decoration: none;
    }

    a:hover {
      color: #ffa500;
    }

    .logo {
      display: block;
      margin: 0 auto 20px;
      max-width: 100px;
      border-radius: 12px;
      box-shadow: 0 0 12px rgba(255, 165, 0, 0.4);
    }
  </style>
</head>
<body>
  <main class="container py-5 text-white">
    <h2 class="text-warning mb-4">Repair Signpack: <%= packId %></h2>
    <p class="text-light">The following image files are missing. Please upload a replacement for each.</p>

    <% if (missing.length === 0) { %>
      <div class="alert alert-success">
        All required files have been uploaded.
        <a href="/signpack?pack=<%= packId %>">Go back to your pack</a>.
      </div>
    <% } else { %>
      <% missing.forEach(file => { %>
        <form action="/signpack/repair/<%= packId %>/upload" method="POST" enctype="multipart/form-data" class="mb-4">
          <input type="hidden" name="filename" value="<%= file %>">
          <div class="card bg-dark-glass border-light shadow-sm p-3">
            <h5 class="text-info mb-2">Missing: <code><%= file %></code></h5>

            <% if (relatedSigns[file]) { %>
              <pre class="bg-dark text-light p-2 rounded mb-3 small" style="font-size: 0.8rem; max-height: 200px; overflow: auto;">
<%= JSON.stringify(relatedSigns[file], null, 2) %>
              </pre>
            <% } %>

            <input type="file" name="file" required class="form-control mb-2" />
            <button type="submit" class="btn btn-warning w-100">Upload Replacement</button>
          </div>
        </form>
      <% }) %>
    <% } %>

    <% if (signsJson) { %>
      <details class="mt-5">
        <summary class="text-warning fs-5">View Raw signs.json</summary>
        <pre class="bg-dark text-light p-3 mt-2 rounded" style="max-height: 400px; overflow-y: auto;">
<%= JSON.stringify(signsJson, null, 2) %>
        </pre>
      </details>
    <% } %>
  </main>
</body>


</html>
