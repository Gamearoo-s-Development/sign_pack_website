<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Create Multi-Block Sign | Signpack Maker</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
</head>
<body class="bg-dark text-light">
  <div class="container py-5">
    <h1 class="text-warning">Create Multi-Block Sign</h1>
    <div class="alert alert-warning text-dark small mt-2" role="alert">
      ⚠️ Multi-block sign generation is experimental. Tile splitting and back generation may not align perfectly with in-game appearance.
    </div>

    <form id="fragmentForm" class="row g-3">
      <div class="col-md-4">
        <label class="form-label">
          Upload Front Image <small class="text-white">(back will be auto-generated)</small>
        </label>
        <input type="file" accept="image/*" class="form-control" required id="largeSign" />
      </div>
      <div class="col-md-2">
        <label class="form-label">Cols</label>
        <input type="number" id="cols" min="1" value="2" class="form-control" required />
      </div>
      <div class="col-md-2">
        <label class="form-label">Rows</label>
        <input type="number" id="rows" min="1" value="2" class="form-control" required />
      </div>
      <div class="col-md-6">
        <label class="form-label">Base Sign Name</label>
        <input type="text" id="baseName" class="form-control" placeholder="e.g. Museum Panel" required />
      </div>
      <div class="col-md-6">
        <label class="form-label">Sign Type Folder</label>
        <input class="form-control" id="signtype_folder" list="folderList" placeholder="e.g. useful_road" required />
      </div>
      <div class="col-md-6">
        <label class="form-label">Sign Type Name</label>
        <input class="form-control" id="signtype_label" list="labelList" placeholder="e.g. Road Signs" required />
      </div>
      <div class="col-12">
        <button class="btn btn-outline-light mt-2" type="submit">
          <i class="fa fa-th me-1"></i> Fragment into Individual Signs
        </button>
      </div>
    </form>

    <div id="fragmentPreview" class="d-flex flex-wrap gap-2 mt-4"></div>

    <datalist id="folderList">
      <% if (selectedPack && selectedPack.types) {
           Object.keys(selectedPack.types).forEach(type => { %>
        <option value="<%= type %>">
      <% }) } %>
    </datalist>
    <datalist id="labelList">
      <% if (selectedPack && selectedPack.types) {
           Object.values(selectedPack.types).forEach(label => { %>
        <option value="<%= label %>">
      <% }) } %>
    </datalist>
  </div>

  <script>
    const existingTypes = <%- JSON.stringify(selectedPack?.types || {}) %>;
    const folderInput = document.getElementById("signtype_folder");
    const labelInput = document.getElementById("signtype_label");

    folderInput.addEventListener("input", () => {
      const folderVal = folderInput.value.trim();
      if (existingTypes[folderVal]) {
        labelInput.value = existingTypes[folderVal];
        labelInput.readOnly = true;
      } else {
        labelInput.readOnly = false;
        labelInput.value = "";
      }
    });

    const fileInput = document.getElementById("largeSign");
    const rowsInput = document.getElementById("rows");
    const colsInput = document.getElementById("cols");
    const baseNameInput = document.getElementById("baseName");
    const typeFolderInput = document.getElementById("signtype_folder");
    const typeLabelInput = document.getElementById("signtype_label");
    const previewContainer = document.getElementById("fragmentPreview");
    const form = document.getElementById("fragmentForm");

    let imageDataUrl = null;
    let frontTileBlobs = [];
    let backTileBlobs = [];

    function padImageToSquare(src, callback) {
      const tempImg = new Image();
      tempImg.onload = () => {
        const maxDim = Math.max(tempImg.width, tempImg.height);
        const canvas = document.createElement("canvas");
        canvas.width = maxDim;
        canvas.height = maxDim;
        const ctx = canvas.getContext("2d");
        ctx.fillStyle = "#00000000";
        ctx.fillRect(0, 0, maxDim, maxDim);
        ctx.drawImage(tempImg, (maxDim - tempImg.width) / 2, (maxDim - tempImg.height) / 2);
        callback(canvas.toDataURL());
      };
      tempImg.src = src;
    }

    function renderPreview() {
      frontTileBlobs = [];
      backTileBlobs = [];
      if (!imageDataUrl) return;

      const rows = parseInt(rowsInput.value);
      const cols = parseInt(colsInput.value);
      if (rows < 1 || cols < 1) return;

      const img = new Image();
      img.onload = () => {
        const tileWidth = img.width / cols;
        const tileHeight = img.height / rows;
        previewContainer.innerHTML = "";

        for (let y = 0; y < rows; y++) {
          for (let x = 0; x < cols; x++) {
            const canvas = document.createElement("canvas");
            canvas.width = tileWidth;
            canvas.height = tileHeight;
            const ctx = canvas.getContext("2d");
            ctx.drawImage(img, x * tileWidth, y * tileHeight, tileWidth, tileHeight, 0, 0, tileWidth, tileHeight);

            const dataURL = canvas.toDataURL();

            canvas.toBlob(blob => {
              const index = y * cols + x;
              const frontFile = new File([blob], `tile_${index}.png`, { type: "image/png" });
              frontTileBlobs.push(frontFile);

              const maskImg = new Image();
              maskImg.onload = () => {
                const shaped = document.createElement("canvas");
                shaped.width = tileWidth;
                shaped.height = tileHeight;
                const backCtx = shaped.getContext("2d");

                backCtx.fillStyle = "#808080";
                backCtx.fillRect(0, 0, tileWidth, tileHeight);
                backCtx.globalCompositeOperation = "destination-in";
                backCtx.save();
                backCtx.translate(tileWidth, 0);
                backCtx.scale(-1, 1);
                backCtx.drawImage(maskImg, 0, 0);
                backCtx.restore();

                shaped.toBlob(backBlob => {
                  const backFile = new File([backBlob], `tile_${index}_back.png`, { type: "image/png" });
                  backTileBlobs.push(backFile);
                }, "image/png");
              };
              maskImg.src = dataURL;
            }, "image/png");

            const thumb = document.createElement("img");
            thumb.src = dataURL;
            thumb.classList.add("border", "rounded", "shadow-sm");
            thumb.style.width = "100px";
            previewContainer.appendChild(thumb);
          }
        }
      };

      padImageToSquare(imageDataUrl, padded => {
        img.src = padded;
      });
    }

    fileInput.addEventListener("change", e => {
      const file = e.target.files[0];
      if (!file) return;
      const reader = new FileReader();
      reader.onload = e => {
        imageDataUrl = e.target.result;
        renderPreview();
      };
      reader.readAsDataURL(file);
    });

    rowsInput.addEventListener("input", renderPreview);
    colsInput.addEventListener("input", renderPreview);

    form.addEventListener("submit", async e => {
      e.preventDefault();
      const fd = new FormData();
      fd.append("baseName", baseNameInput.value);
      fd.append("signtype_folder", typeFolderInput.value);
      fd.append("signtype_label", typeLabelInput.value);
      fd.append("rows", rowsInput.value);
      fd.append("cols", colsInput.value);
      frontTileBlobs.forEach(f => fd.append("frontTiles", f));
      backTileBlobs.forEach(f => fd.append("backTiles", f));
      const response = await fetch(`/signpack/fragment-upload/<%= selectedPack?.pack_id || '' %>`, {
        method: "POST",
        body: fd
      });
      if (response.ok) {
        location.href = `/signpack?pack=<%= selectedPack?.pack_id || '' %>`;
      } else {
        alert("Upload failed.");
      }
    });
  </script>
</body>
</html>
