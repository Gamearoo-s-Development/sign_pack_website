  <script>
    (function () {
      function applyRamAiDrawerOpen(open) {
        var drawer = document.getElementById("ramAiDrawer");
        var backdrop = document.getElementById("ramAiBackdrop");
        var launcher = document.getElementById("ramAiLauncherBtn");
        if (!drawer || !launcher) return false;
        var wantOpen = typeof open === "boolean" ? open : !drawer.classList.contains("is-open");
        drawer.classList.toggle("is-open", wantOpen);
        drawer.setAttribute("aria-hidden", wantOpen ? "false" : "true");
        launcher.setAttribute("aria-expanded", wantOpen ? "true" : "false");
        launcher.classList.toggle("is-drawer-open", wantOpen);
        if (backdrop) backdrop.hidden = !wantOpen;
        if (wantOpen) {
          var composer = document.getElementById("ramAiCustomPrompt");
          if (composer) composer.focus();
        }
        return wantOpen;
      }
      window.toggleRamAiDrawer = applyRamAiDrawerOpen;

      function bindRamAiDrawerFallback() {
        var launcher = document.getElementById("ramAiLauncherBtn");
        var closeBtn = document.getElementById("ramAiCloseBtn");
        var backdrop = document.getElementById("ramAiBackdrop");
        if (launcher && !launcher.dataset.ramAiFallbackBound) {
          launcher.dataset.ramAiFallbackBound = "1";
          launcher.addEventListener("click", function (e) {
            if (window.__ramAiHelperReady) return;
            e.preventDefault();
            applyRamAiDrawerOpen();
          });
        }
        if (closeBtn && !closeBtn.dataset.ramAiFallbackBound) {
          closeBtn.dataset.ramAiFallbackBound = "1";
          closeBtn.addEventListener("click", function () {
            if (window.__ramAiHelperReady) return;
            applyRamAiDrawerOpen(false);
          });
        }
        if (backdrop && !backdrop.dataset.ramAiFallbackBound) {
          backdrop.dataset.ramAiFallbackBound = "1";
          backdrop.addEventListener("click", function () {
            if (window.__ramAiHelperReady) return;
            applyRamAiDrawerOpen(false);
          });
        }
        if (!window.__ramAiEscapeBound) {
          window.__ramAiEscapeBound = true;
          document.addEventListener("keydown", function (e) {
            if (e.key !== "Escape") return;
            var drawer = document.getElementById("ramAiDrawer");
            if (!drawer || !drawer.classList.contains("is-open")) return;
            if (window.__ramAiHelperReady) return;
            applyRamAiDrawerOpen(false);
          });
        }
      }

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", bindRamAiDrawerFallback);
      } else {
        bindRamAiDrawerFallback();
      }
    })();
  </script>
<% } %>

<script>
  window.cutMode = false;
  let cutSignIds = [];
  let currentEntry = null;
document.addEventListener('DOMContentLoaded', () => {
  const signList = document.getElementById('signList');
  if (!signList) return;

 

  // Create custom context menu
  const menu = document.createElement('div');
  menu.id = 'customContextMenu';
  menu.style.position = 'absolute';
  menu.style.background = 'rgba(0, 0, 0, 0.9)';
  menu.style.border = '1px solid #ff5600';
  menu.style.borderRadius = '8px';
  menu.style.color = 'white';
  menu.style.padding = '0.5rem';
  menu.style.zIndex = 9999;
  menu.style.display = 'none';
  menu.style.fontSize = '0.9rem';
  menu.innerHTML = `
  <div id="contextSelect" style="padding: 4px 8px; cursor: pointer;">🔍 Select This Sign <span data-bs-toggle="tooltip" title="Select This Sign." class="help-tip">?</span></div>
  <div id="contextCut" style="padding: 4px 8px; cursor: pointer;">✂️ Cut for Reorder <span data-bs-toggle="tooltip" title="Add this to a multiple sign move operation." class="help-tip">?</span></div>
  <div id="contextSave" style="padding: 4px 8px; cursor: pointer;">💾 Download Image <span data-bs-toggle="tooltip" title="Download This front image for the sign." class="help-tip">?</span></div>
`;

document.addEventListener('click', () => {
  menu.style.display = 'none';
  document.querySelectorAll('.sign-entry').forEach(el => el.classList.remove('context-active'));
});



  document.body.appendChild(menu);

  signList.addEventListener('contextmenu', (e) => {
    e.preventDefault();
  
    // Get the *actual sign-entry* element
    const entry = e.target.closest('.sign-entry');
    if (!entry || !signList.contains(entry)) {
      console.warn("❌ Right-click target was not a sign-entry");
      return;
    }
  
    currentEntry = entry;
  
    // Optional: Visual feedback
    document.querySelectorAll('.sign-entry').forEach(el => el.classList.remove('context-active'));
    entry.classList.add('context-active');
  
    // Show menu
    menu.style.left = `${e.pageX}px`;
    menu.style.top = `${e.pageY}px`;
    menu.style.display = 'block';
  });

  // Option 1: Select sign and load
  document.getElementById('contextSelect').addEventListener('click', () => {
    if (currentEntry) {
      const all = Array.from(document.querySelectorAll('.sign-entry'));
      const index = all.indexOf(currentEntry) + 1;

      const url = new URL(window.location.href);
      url.searchParams.set('signIndex', index);
      window.location.href = url.toString();
    }
    menu.style.display = 'none';
  });

  

  // Option 2: Toggle Cut Mode for this sign
  document.getElementById('contextCut').addEventListener('click', () => {
    if (!currentEntry) return;
    const id = currentEntry.dataset.id;

    if (!window.cutMode) {
      alert("✂️ Cut Mode is not active.");
      menu.style.display = 'none';
      return;
    }

    if (currentEntry.classList.contains('cutting')) {
      currentEntry.classList.remove('cutting');
      cutSignIds = cutSignIds.filter(cutId => cutId !== id);
    } else {
      currentEntry.classList.add('cutting');
      cutSignIds.push(id);
    }

    menu.style.display = 'none';
  });

  // Hide menu on outside click or scroll
  document.addEventListener('click', () => menu.style.display = 'none');
  document.addEventListener('scroll', () => menu.style.display = 'none');
});

document.addEventListener('click', async (e) => {
  if (e.target.id === 'contextSave') {
    console.log("💾 Save clicked");

    if (!currentEntry) return;

    const img = currentEntry.querySelector('img');
    if (!img || !img.src) {
      alert("No image found to download.");
      return;
    }
    
    try {
      const image = new Image();
      image.crossOrigin = 'anonymous';
      image.src = img.src;

      await image.decode();

      const canvas = document.createElement('canvas');
      canvas.width = image.naturalWidth || 128;
      canvas.height = image.naturalHeight || 128;
      const ctx = canvas.getContext('2d');
      ctx.drawImage(image, 0, 0);

      canvas.toBlob(blob => {
        const link = document.createElement('a');
        link.href = URL.createObjectURL(blob);
        link.download = `${img.alt}.png`;
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
      }, 'image/png');
    } catch (err) {
      console.error("❌ Failed to save image:", err);
      alert("Failed to download image. It might be blocked by CORS or not loaded.");
    }

    // Hide the menu
    document.getElementById('customContextMenu').style.display = 'none';
  }
});





  function toggleCutMode() {
    window.cutMode = !window.cutMode;
  cutSignIds = [];
  document.getElementById("cutModeBtn").classList.toggle("btn-danger", cutMode);
  document.getElementById("cutModeBtn").innerText = cutMode ? "❌ Exit Cut Mode" : "✂️ Enter Cut Mode";

  document.querySelectorAll(".sign-entry").forEach(el => el.classList.remove("cutting"));
}


  function handleSignClick(entry) {
  if (!cutMode) return;

  const currentId = entry.dataset.id;

  if (cutSignIds.length === 0 || !entry.classList.contains("cutting")) {
    // Select or toggle selection
    if (entry.classList.contains("cutting")) {
      entry.classList.remove("cutting");
      cutSignIds = cutSignIds.filter(id => id !== currentId);
    } else {
      entry.classList.add("cutting");
      cutSignIds.push(currentId);
    }
  } else {
    // Paste all before this entry
    const container = document.getElementById("signList");
    const targetEl = container.querySelector(`[data-id='${currentId}']`);



    cutSignIds.forEach(id => {
      const cutEl = container.querySelector(`[data-id='${id}']`);

      if (cutEl) container.insertBefore(cutEl, targetEl);
    });

    // Reset selection
    cutSignIds = [];
    document.querySelectorAll(".sign-entry").forEach(el => el.classList.remove("cutting"));
  }
}


  document.addEventListener("DOMContentLoaded", () => {
    document.querySelectorAll(".sign-entry").forEach(entry => {
      entry.addEventListener("click", () => handleSignClick(entry));
    });
  });
</script>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    const signInput = document.querySelector('input[name="signs"]');
    if (!signInput) return;
  
    signInput.addEventListener('change', function (e) {
      const file = e.target.files[0];
      const reader = new FileReader();
      if (!file) return;
  
      // Auto-generate sign name if blank
      const signTextInput = document.getElementById('signText');
      if (signTextInput && !signTextInput.value.trim()) {
        let name = file.name.replace(/\.[^/.]+$/, ''); // remove extension
        name = name
          .replace(/[_-]+/g, ' ')                // underscores/dashes → space
          .replace(/([a-z])([A-Z])/g, '$1 $2')   // camelCase → spaced
          .replace(/\s+/g, ' ')                  // normalize spaces
          .trim()
          .replace(/\b\w/g, l => l.toUpperCase()); // capitalize each word
  
        signTextInput.value = name;
      }
  
      // Image preview
      const img = document.getElementById('previewSignImage');
      reader.onload = function (event) {
        if (img) {
          img.src = event.target.result;
          img.style.display = 'block';
          img.onload = updateSignPreview;
        }
      };
      reader.readAsDataURL(file);
    });
  });
  </script>

  
  

