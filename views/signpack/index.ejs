<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Signpack Maker | Traffic Control Mod</title>
  <link rel="icon" type="image/x-icon" href="https://gamearoo.top/ram-api-img/bc91c29e-d0af-460f-a30e-541cd5b57179.png" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="shortcut icon" href="/images/sign.png" type="image/png" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
  <link rel="stylesheet" href="/css/brand.css" />
  <link rel="stylesheet" href="/css/signpack.css" />
  <link rel="stylesheet" href="/css/editor.css" />
  <link rel="stylesheet" href="/css/ram-ai-chat.css" />
  <script src="/js/site-config.js"></script>
  <script src="/js/signpack-guide.js"></script>
</head>

<body class="editor-app"
  data-ram-ai-enabled="<%= (typeof ramAiEnabled !== 'undefined' && ramAiEnabled) ? 'true' : 'false' %>"
  data-ram-ai-poll-ms="<%= typeof ramAiPollMs !== 'undefined' ? ramAiPollMs : 5000 %>"
  data-ram-ai-debug="<%= (typeof ramAiDebug !== 'undefined' && ramAiDebug) ? 'true' : 'false' %>"
  data-user-avatar="<%= user.avatarUrl || '' %>"
  data-user-initials="<%= user.initials %>"
  data-user-display="<%= user.displayName %>"
  data-user-username="<%= user.username || '' %>">

<%
  const TC_SIGNPACK_WIKI = "https://github.com/CSX8600/trafficcontrol/wiki/Making-a-Custom-Sign-Pack";
  const TC_WIKI_TITLE = "Open the official Traffic Control signpack guide";
%>

  <script>
    function updateSignIndex(signIndex) {
      console.log(signIndex);
      const url = new URL(window.location.href);
      <% if (selectedPack) { %>
        url.searchParams.set('pack', '<%= selectedPack.pack_id %>');
      <% } %>
      if (signIndex !== "") {
        url.searchParams.set('signIndex', signIndex);
      } else {
        url.searchParams.delete('signIndex');
      }
      window.location.href = url.toString();
    }
  
    function downloadAndReload(packId) {
      const frame = document.getElementById("downloadFrame");
      frame.src = `/signpack/download/${packId}`;
  
      setTimeout(() => {
        if (confirm("Export complete. Would you like to remove this pack from the site now?")) {
          fetch(`/signpack/delete-pack/${packId}`, {
            method: "POST"
          })
          .then(res => res.json())
          .then(data => {
            if (data.success) {
              alert("Pack deleted.");
              location.href = "/signpack";
            } else {
              alert("Failed to delete pack.");
            }
          });
        } else {
          alert("Pack was not deleted and remains available.");
        }
      }, 3000);
    }

    function removeAndReload(packId) {
      
  
      setTimeout(() => {
        if (confirm("Are you sure you want to remove this pack from the site? This action cannot be undone.")) {
          fetch(`/signpack/delete-pack/${packId}`, {
            method: "POST"
          })
          .then(res => res.json())
          .then(data => {
            if (data.success) {
              alert("Pack deleted.");
              location.href = "/signpack";
            } else {
              alert("Failed to delete pack.");
            }
          });
        } else {
          alert("Pack was not deleted and remains available.");
        }
      }, 3000);
    }
  
    let textlineIndex = 0;
  
    function addTextline(data = {}) {
      const container = document.getElementById("textlinesContainer");
      const wrapper = document.createElement("div");
      wrapper.className = "editor-textline-card text-white";
      wrapper.dataset.index = textlineIndex;
      const ramOn = document.body.getAttribute("data-ram-ai-enabled") === "true";
      const ramFieldBtn = (field) =>
        ramOn
          ? `<button type="button" class="btn-ram-ai-field" data-ram-ai-field="${field}" title="Ask Ram AI" aria-label="Ram AI explain ${field}"><i class="fa fa-wand-magic-sparkles"></i></button>`
          : "";

      wrapper.innerHTML = `
        <div class="d-flex justify-content-between align-items-center mb-2">
          <strong>Textline #${textlineIndex + 1}</strong>
          <button type="button" class="btn btn-sm btn-danger" onclick="this.closest('.editor-textline-card').remove()">Remove</button>
        </div>
        <div class="row g-2">
          <div class="col-md-4">
  <label class="form-label">
    Label <span class="text-danger">*</span>
    <span data-bs-toggle="tooltip" title="Required. Label shown above the in-game text field (signs.json: label)." class="help-tip">?</span>
  </label>
  <input class="form-control" name="textlines[${textlineIndex}][label]" placeholder="Label" value="${data.label || ''}">
</div>

          <div class="col-md-2">
            <label class="form-label">
    X <span class="text-danger">*</span>
    <span data-bs-toggle="tooltip" title="Required. X position on the 16×16 text grid (0–16)." class="help-tip">?</span>
  </label>
            <input class="form-control" name="textlines[${textlineIndex}][x]" placeholder="X" value="${data.x || ''}" /></div>
          <div class="col-md-2">
              <label class="form-label">
    Y <span class="text-danger">*</span>
    <span data-bs-toggle="tooltip" title="Required. Y position on the 16×16 text grid (0–16)." class="help-tip">?</span>
  </label>
            
            <input class="form-control" name="textlines[${textlineIndex}][y]" placeholder="Y" value="${data.y || ''}" /></div>
          <div class="col-md-2">
              <label class="form-label">
    Width <span class="text-danger">*</span>
    <span data-bs-toggle="tooltip" title="Required. Width of the text area on the 16×16 grid." class="help-tip">?</span>
  </label>
            
            <input class="form-control" name="textlines[${textlineIndex}][width]" placeholder="Width" value="${data.width || ''}" /></div>
          <div class="col-md-2">
               <label class="form-label">
    Max Length 
    <span data-bs-toggle="tooltip" title="Optional. Maximum characters players can enter for this line." class="help-tip">?</span>
  </label>
            <input class="form-control" name="textlines[${textlineIndex}][maxlength]" placeholder="Max" value="${data.maxlength || ''}" /></div>
          <div class="col-md-2">
              <label class="form-label">
    X Scale 
    <span data-bs-toggle="tooltip" title='How to scale the text on the x-axis. 1 is no scaling, < 1 is scale in, > 1 is scale out.' class="help-tip">?</span>
  </label>
            <input class="form-control" name="textlines[${textlineIndex}][xscale]" placeholder="X Scale" value="${data.xscale || ''}" /></div>
          <div class="col-md-2">
             <label class="form-label">
    Y Scale 
    <span data-bs-toggle="tooltip" title='How to scale the text on the y-axis. 1 is no scaling, < 1 is scale in, > 1 is scale out.' class="help-tip">?</span>
  </label>
            <input class="form-control" name="textlines[${textlineIndex}][yscale]" placeholder="Y Scale" value="${data.yscale || ''}" /></div>
          <div class="col-md-2">
              <label class="form-label">
    H Align
    <span data-bs-toggle="tooltip" title='Horizontal text alignment. Options are: left, center, right' class="help-tip">?</span>
  </label>
            <select class="form-select" name="textlines[${textlineIndex}][halign]">
  <option value="left" ${data.halign === 'left' ? 'selected' : ''}>Left</option>
  <option value="center" ${data.halign === 'center' ? 'selected' : ''}>Center</option>
  <option value="right" ${data.halign === 'right' ? 'selected' : ''}>Right</option>
</select> </div>
          <div class="col-md-2">
               <label class="form-label">
    Y Align
    <span data-bs-toggle="tooltip" title='Vertical text alignment. Options are: top, center, bottom' class="help-tip">?</span>
  </label>
            <select class="form-select" name="textlines[${textlineIndex}][valign]">
  <option value="top" ${data.valign === 'top' ? 'selected' : ''}>Top</option>
  <option value="center" ${data.valign === 'center' ? 'selected' : ''}>Center</option>
  <option value="bottom" ${data.valign === 'bottom' ? 'selected' : ''}>Bottom</option>
</select></div>
          <div class="col-md-2">
             <label class="form-label label-with-ram">
    Color
    <span data-bs-toggle="tooltip" title="Required. Stored as an integer in signs.json (e.g. red #FF0000 → 16711680). This editor converts from the color picker." class="help-tip">?</span>${ramFieldBtn("color")}
  </label>
            <input class="form-control form-control-color" type="color" name="textlines[${textlineIndex}][color]" value="${
              typeof data.color === 'number' ? '#' + data.color.toString(16).padStart(6, '0') : (data.color || '#000000')
            }" title="Text Color" />
          </div>
        </div>
      `;
      container.appendChild(wrapper);
      wrapper.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function (t) {
        new bootstrap.Tooltip(t);
      });
      var form = document.getElementById("signpackForm");
      if (form) form.dispatchEvent(new Event("change", { bubbles: true }));
      textlineIndex++;
    }
  
    function selectExistingBack(path, filename) {
      document.getElementById("selectedBackImage").value = path;
  
      document.querySelectorAll(".back-image").forEach(img =>
        img.classList.remove("selected")
      );
  
      const selectedImg = document.querySelector(`img[data-back-preview="${filename}"]`);
      if (selectedImg) {
        selectedImg.classList.add("selected");
  
        const preview = document.getElementById("backImagePreview");
        if (preview) {
          preview.src = selectedImg.src;
          preview.style.display = "block";
        }
      } else {
        console.warn("No match found for filename:", filename);
      }
    }
  
    function handleSignClick(entry) {
      if (!cutMode) return;
  
      const currentId = entry.dataset.id;
  
      if (cutSignIds.length === 0 || !entry.classList.contains("cutting")) {
        if (entry.classList.contains("cutting")) {
          entry.classList.remove("cutting");
          cutSignIds = cutSignIds.filter(id => id !== currentId);
        } else {
          entry.classList.add("cutting");
          cutSignIds.push(currentId);
        }
      } else {
        const container = document.getElementById("signList");
        const targetEl = container.querySelector(`[data-id='${currentId}']`);
  
        cutSignIds.forEach(id => {
          const cutEl = container.querySelector(`[data-id='${id}']`);
          if (cutEl) container.insertBefore(cutEl, targetEl);
        });
  
        cutSignIds = [];
        document.querySelectorAll(".sign-entry").forEach(el => el.classList.remove("cutting"));
      }
    }
  
    document.addEventListener("DOMContentLoaded", () => {
      document.querySelectorAll(".sign-entry").forEach(entry => {
        entry.addEventListener("click", () => handleSignClick(entry));
      });
  
      const signInput = document.getElementById('frontImageInput') || document.querySelector('input[name="signs"]');
      if (signInput) {
        signInput.addEventListener('change', function (e) {
          const file = e.target.files[0];
          const signTextInput = document.getElementById('signText');
          if (signTextInput && !signTextInput.value.trim()) {
            let name = file.name.replace(/\.[^/.]+$/, '')
              .replace(/[_-]+/g, ' ')
              .replace(/([a-z])([A-Z])/g, '$1 $2')
              .replace(/\s+/g, ' ')
              .trim()
              .replace(/\b\w/g, l => l.toUpperCase());
            signTextInput.value = name;
          }
  
          const img = document.getElementById('previewSignImage');
          const reader = new FileReader();
          reader.onload = function (event) {
            img.src = event.target.result;
            img.style.display = 'block';
            img.onload = updateSignPreview;
          };
          reader.readAsDataURL(file);
        });
      }
  
      // Tooltip support
      const tooltipList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
      tooltipList.forEach(t => new bootstrap.Tooltip(t));
    });
  
    // Back image preview handler
    document.addEventListener('DOMContentLoaded', () => {
      const input = document.getElementById('backImageInput');
      const preview = document.getElementById('backImagePreview');
  
      if (input && preview) {
        input.addEventListener('change', e => {
          const file = e.target.files[0];
          if (!file) return;
  
          const reader = new FileReader();
          reader.onload = e => {
            preview.src = e.target.result;
            preview.style.display = 'block';
          };
          reader.readAsDataURL(file);
        });
      }
    });
  </script>

  <% if (selectedSign) { %>
    <script>
      window.addEventListener("DOMContentLoaded", () => {
        const s = <%- JSON.stringify(selectedSign) %>;
        console.log("Loaded sign:", s);
  
        if (!s) return;
  
        let half = false;
        if (s.halfheight) half = true;
  
        document.getElementById("signText").value = s.name || '';
        document.getElementById("signtype_folder").value = s.type || '';
        document.getElementById("halfheight").checked = half;
        document.getElementById("signTool").value = s.tooltip || '';
  
        const container = document.getElementById("textlinesContainer");
        container.innerHTML = '';
        textlineIndex = 0;
  
        if (Array.isArray(s.textlines)) {
          s.textlines.forEach(line => addTextline(line));
        } else {
          console.warn("No textlines or not an array:", s.textlines);
        }
      });
    </script>
  <% } %>
<div class="editor-shell">
  <header class="editor-topbar">
    <div class="editor-topbar-inner">
      <button type="button" class="editor-sidebar-toggle" id="editorSidebarToggle" aria-label="Open menu">
        <i class="fa fa-bars"></i>
      </button>
      <%- include('../partials/brand', { brandHref: '/', brandClass: 'editor-brand', brandTitleTag: 'h1' }) %>
      <a href="#section-signpack-guide" class="editor-btn editor-btn-ghost editor-btn ms-2" data-editor-scroll="#section-signpack-guide" title="Signpack format guide">
        <i class="fa fa-circle-question"></i> <span class="btn-label">Help</span>
      </a>
      <div class="editor-topbar-actions">
        <%- include('../partials/editor-user-menu') %>
      </div>
    </div>
  </header>

  <div class="editor-sidebar-overlay" id="editorSidebarOverlay" aria-hidden="true"></div>

  <div class="editor-body">
    <aside class="editor-sidebar" id="editorSidebar" aria-label="Editor navigation">
      <a href="/signpack" class="editor-sidebar-link is-active" data-editor-nav-href><i class="fa fa-gauge-high"></i> Dashboard</a>
      <button type="button" class="editor-sidebar-link" data-editor-scroll="#section-signpack-selection"><i class="fa fa-folder-open"></i> My Signpacks</button>
      <a href="/signpack?pack=new" class="editor-sidebar-link" data-editor-nav-href><i class="fa fa-plus"></i> Create New</a>
      <button type="button" class="editor-sidebar-link" data-editor-scroll="#section-import-signpack"><i class="fa fa-file-import"></i> Import Signpack</button>
      <% if (selectedPack) { %>
        <button type="button" class="editor-sidebar-link" data-export-pack="<%= selectedPack.pack_id %>"><i class="fa fa-download"></i> Export Signpack</button>
      <% } else { %>
        <span class="editor-sidebar-link is-disabled"><i class="fa fa-download"></i> Export Signpack</span>
      <% } %>
      <a href="/account" class="editor-sidebar-link" data-editor-nav-href><i class="fa fa-user-gear"></i> Account Settings</a>
      <a href="/app" class="editor-sidebar-link" data-editor-nav-href><i class="fa fa-desktop"></i> Desktop App</a>
      <button type="button" class="editor-sidebar-link" data-editor-scroll="#section-signpack-guide"><i class="fa fa-book"></i> Signpack Guide</button>
      <button type="button" class="editor-sidebar-link" data-editor-scroll="#section-ram-ai"><i class="fa fa-wand-magic-sparkles"></i> Ram AI Helper</button>
      <a href="<%= TC_SIGNPACK_WIKI %>" target="_blank" rel="noopener noreferrer" title="<%= TC_WIKI_TITLE %>" class="editor-sidebar-link"><i class="fa fa-external-link"></i> Traffic Control Wiki</a>
      <div class="editor-sidebar-help">
        <p>Need help? Report issues or contribute on GitHub.</p>
        <a href="#" data-signpack-github class="btn btn-sm editor-btn-accent-outline w-100"><i class="fa fa-github me-1"></i> View on GitHub</a>
      </div>
    </aside>

    <div class="editor-content">
      <div class="editor-page-head" id="section-help">
        <h2><i class="fa fa-pen-ruler"></i> Create or Manage Your Signpack</h2>
        <p>Upload, edit, and export custom signpacks for the Traffic Control Mod.</p>
        <div class="editor-page-meta">
          <span class="editor-legend-inline"><span class="help-tip" data-bs-toggle="tooltip" title="Field help follows the official Traffic Control signpack wiki">?</span> Help tips &nbsp;·&nbsp; <span class="req-mark">*</span> Required</span>
          <a href="<%= TC_SIGNPACK_WIKI %>" target="_blank" rel="noopener noreferrer" title="<%= TC_WIKI_TITLE %>" class="btn btn-sm editor-btn-accent-outline">Traffic Control Signpack Wiki</a>
        </div>
      </div>

      <section class="editor-card editor-guide-card" id="section-signpack-guide">
        <div class="editor-section-head">
          <span class="editor-section-num"><i class="fa fa-book"></i></span>
          <h3>Signpack Guide</h3>
        </div>
        <p class="editor-guide-intro">
          Quick reference based on the
          <a href="<%= TC_SIGNPACK_WIKI %>" target="_blank" rel="noopener noreferrer" title="<%= TC_WIKI_TITLE %>">Traffic Control “Making a Custom Sign Pack” wiki</a>.
          Signpack Maker follows the same ZIP + <code>signs.json</code> structure.
        </p>
        <div class="editor-guide-links">
          <a href="#" data-editor-scroll="#section-import-signpack" class="btn btn-sm editor-btn-ghost">Import ZIP</a>
          <a href="#" data-editor-scroll="#section-images" class="btn btn-sm editor-btn-ghost">Images (PNG)</a>
          <a href="#" data-editor-scroll="#section-textlines" class="btn btn-sm editor-btn-ghost">Textlines</a>
        </div>
        <div class="editor-guide-grid">
          <div class="editor-guide-block">
            <h4>Pack file</h4>
            <ul>
              <li>ZIP archive with <code>signs.json</code> at the root</li>
              <li>Textures: <strong>PNG</strong>, square sizes (16×16, 32×32, …)</li>
              <li>Default folders: circle, diamond, misc, rectangle, square, triangle</li>
            </ul>
          </div>
          <div class="editor-guide-block">
            <h4>Required pack fields</h4>
            <ul>
              <li><code>name</code>, <code>pack_id</code> (UUID)</li>
              <li><code>signs</code> array</li>
              <li>Optional: <code>author</code>, <code>types</code></li>
            </ul>
          </div>
          <div class="editor-guide-block">
            <h4>Required sign fields</h4>
            <ul>
              <li><code>id</code> (UUID), <code>name</code>, <code>type</code>, <code>front</code></li>
              <li>Optional: <code>back</code>, <code>tooltip</code>, <code>halfheight</code>, <code>textlines</code></li>
              <li>Do not use deprecated <code>variant</code> on new packs</li>
            </ul>
          </div>
          <div class="editor-guide-block">
            <h4>Textlines (16×16 grid)</h4>
            <ul>
              <li>Required: <code>label</code>, <code>x</code>, <code>y</code>, <code>width</code>, <code>color</code> (integer)</li>
              <li>Optional: <code>maxlength</code>, scales, <code>halign</code>, <code>valign</code></li>
              <li>Example: red <code>#FF0000</code> → <code>16711680</code></li>
            </ul>
          </div>
          <div class="editor-guide-block">
            <h4>In-game testing</h4>
            <ul>
              <li>Copy ZIP to <code>.minecraft/tc_signpacks/</code></li>
              <li>Reload packs: <strong>F3 + ]</strong></li>
            </ul>
          </div>
        </div>
        <p class="editor-guide-credit">
          Format reference:
          <a href="<%= TC_SIGNPACK_WIKI %>" target="_blank" rel="noopener noreferrer" title="<%= TC_WIKI_TITLE %>">github.com/CSX8600/trafficcontrol wiki</a>
          — see also <code>docs/SIGNPACK_GUIDE.md</code> in this repository.
        </p>
      </section>

      <div id="guideValidationBanner" class="editor-validation-banner" hidden aria-live="polite"></div>

      <section id="section-ram-ai" class="ram-ai-anchor">
        <% if (!ramAiEnabled) { %>
          <div class="editor-card editor-ram-ai-card is-disabled-panel">
            <div class="editor-section-head">
              <span class="editor-section-num"><i class="fa fa-wand-magic-sparkles"></i></span>
              <h3>Ram AI Helper</h3>
            </div>
            <p class="text-secondary small mb-0">
              Ram AI is not available on this server right now. The editor works fully without it — upload, save, and export are unchanged.
            </p>
          </div>
        <% } else { %>
          <div class="editor-card editor-ram-ai-card">
            <div class="editor-section-head">
              <span class="editor-section-num"><i class="fa fa-wand-magic-sparkles"></i></span>
              <h3>Ram AI Helper</h3>
            </div>
            <p class="text-secondary small mb-3">
              Open the <strong>Ram AI</strong> button at the bottom-right for chat assistance while you edit. Nothing is sent until you ask.
            </p>
            <div class="editor-ram-ai-help-grid">
              <div class="editor-ram-ai-help-card">
                <i class="fa fa-shield-halved" aria-hidden="true"></i>
                <strong>Secure by design</strong>
                <span>Handled through Signpack Maker — your credentials stay protected.</span>
              </div>
              <div class="editor-ram-ai-help-card">
                <i class="fa fa-hourglass-half" aria-hidden="true"></i>
                <strong>Queue-aware</strong>
                <span>Live status while Ram AI generates — cancel anytime.</span>
              </div>
              <div class="editor-ram-ai-help-card">
                <i class="fa fa-lightbulb" aria-hidden="true"></i>
                <strong>Advisory only</strong>
                <span>Suggestions you review — you control what gets saved.</span>
              </div>
              <div class="editor-ram-ai-help-card">
                <i class="fa fa-circle-check" aria-hidden="true"></i>
                <strong>Optional</strong>
                <span>Editing works the same if you never open the assistant.</span>
              </div>
            </div>
          </div>
        <% } %>
      </section>

      <% if (selectedPack) { %>
        <script type="application/json" id="ramAiPackSnapshot"><%- JSON.stringify(selectedPack) %></script>
      <% } %>

      <section class="editor-card" id="section-signpack-selection">
        <div class="editor-section-head">
          <span class="editor-section-num">1</span>
          <h3>Signpack Selection</h3>
        </div>
        <div class="row g-4">
          <div class="col-lg-6" id="section-import-signpack">
            <form method="POST" action="/signpack/upload" enctype="multipart/form-data">
              <label class="form-label" for="signpackFile">Upload Existing Signpack <span data-bs-toggle="tooltip" title="ZIP archive with signs.json at the root (Traffic Control signpack format)." class="help-tip">?</span></label>
              <div class="editor-dropzone" data-editor-dropzone>
                <input class="editor-file-input" type="file" name="signpackFile" id="signpackFile" accept=".zip,application/zip" required />
                <div class="editor-dropzone-icon"><i class="fa fa-cloud-arrow-up"></i></div>
                <p class="editor-dropzone-title">Select a .zip or .json signpack file</p>
                <p class="editor-dropzone-hint">Drag and drop here, or browse</p>
                <div class="editor-dropzone-actions">
                  <button type="button" class="btn btn-sm editor-btn-accent-outline" data-dropzone-browse>Choose File</button>
                </div>
                <span class="editor-dropzone-name" data-dropzone-name></span>
              </div>
              <button type="submit" class="btn btn-warning btn-sm mt-3"><i class="fa fa-upload me-1"></i> Upload Signpack</button>
              <% if (selectedPack) { %>
                <a href="/signpack/multiblock/<%= selectedPack.pack_id %>" class="btn btn-sm editor-btn-ghost mt-3 ms-2">
