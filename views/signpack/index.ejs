          <% if (selectedSign && selectedSign.front && selectedPack) { %>
            <img id="previewSignImage" src="/users/<%= user.username %>/packs/<%= selectedPack.pack_id %>/<%= selectedSign.type %>/<%= selectedSign.front %>" style="width: 400px; display: block;" class="border rounded shadow-sm" />
          <% } else { %>
            <img id="previewSignImage" src="#" style="width: 400px; display: none;" class="border rounded shadow-sm" />
          <% } %>
        </div>
      </div>
      

      <div class="mb-4">
        <label class="form-label text-black">Textlines <span data-bs-toggle="tooltip" title="Manage TextLines of a sign." style="cursor: help; color: #0dcaf0; font-weight: bold;">?</span></label>
        <div id="textlinesContainer"></div>
        <button type="button" class="btn btn-outline-primary mt-2" onclick="addTextline()">+ Add Textline <span data-bs-toggle="tooltip" title="Adds A new text line." style="cursor: help; color: #0dcaf0; font-weight: bold;">?</span></button>
