      <div class="mb-4">
        <label class="form-label label-with-ram">Sign Type Display Name <% if (!selectedSign || !selectedSign.type) { %><span class="req-mark">*</span><% } %> <span data-bs-toggle="tooltip" title="Optional pack types map: folder name → in-game category label (e.g. Road Signs)." class="help-tip">?</span><% if (ramAiEnabled) { %><button type="button" class="btn-ram-ai-field" data-ram-ai-field="signtype_label" title="Ask Ram AI" aria-label="Ram AI explain type label"><i class="fa fa-wand-magic-sparkles"></i></button><% } %></label>
        <input class="form-control mb-2" name="signtype_label" id="signtype_label"
          placeholder="e.g. Road Signs" value="<%= selectedPack?.types?.[selectedSign?.type] || '' %>" list="labelList" <%= !selectedSign || !selectedSign.type ? 'required' : '' %>  />
      </div>
      
      <datalist id="folderList">
        <% if (selectedPack && selectedPack.types) { %>
          <% Object.keys(selectedPack.types).forEach(type => { %>
            <option value="<%= type %>">
          <% }) %>
        <% } %>
      </datalist>
      
      <datalist id="labelList">
        <% if (selectedPack && selectedPack.types) { %>
          <% Object.values(selectedPack.types).forEach(label => { %>
            <option value="<%= label %>">
          <% }) %>
        <% } %>
      </datalist>
      
      
      <script>
        const existingTypes = <%- JSON.stringify(selectedPack?.types || {}) %>;
      
        const folderInput = document.getElementById("signtype_folder");
        const labelInput = document.getElementById("signtype_label");
      
        folderInput.addEventListener("input", () => {
          const folderValue = folderInput.value.trim();
      
          if (existingTypes.hasOwnProperty(folderValue)) {
            labelInput.value = existingTypes[folderValue];
            labelInput.disabled = true;
          } else {
            labelInput.value = "";
            labelInput.disabled = false;
          }
        });
      
        // Auto-trigger on page load in case it's prefilled
        window.addEventListener("DOMContentLoaded", () => {
          folderInput.dispatchEvent(new Event("input"));
        });
      </script>
      
      <div class="mb-4">
        <label class="form-label label-with-ram">Sign Tooltip  <span data-bs-toggle="tooltip" title="Optional sign field: tooltip — short in-game help text for this sign." class="help-tip">?</span><% if (ramAiEnabled) { %><button type="button" class="btn-ram-ai-field" data-ram-ai-field="signTool" title="Ask Ram AI" aria-label="Ram AI explain tooltip"><i class="fa fa-wand-magic-sparkles"></i></button><% } %></label>
        <input class="form-control"  name="signstool"  id="signTool" />
