      <div class="d-flex flex-wrap gap-2">
        <button class="btn btn-warning fw-bold"><i class="fa fa-plus me-1"></i>Save Sign <span data-bs-toggle="tooltip" title="Saves the new sign to the json file." style="cursor: help; color: #0dcaf0; font-weight: bold;">?</span></button>
      
        

        <% if (selectedPack) { %>
