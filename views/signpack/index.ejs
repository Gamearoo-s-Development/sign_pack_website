        <input class="form-control mb-2" name="signtype_folder" id="signtype_folder"
          placeholder="e.g. useful_road" value="<%= selectedSign?.type || '' %>" list="folderList" <%= !selectedSign || !selectedSign.type ? 'required' : '' %> />
