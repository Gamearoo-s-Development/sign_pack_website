<section class="upload-section py-5">
  <div class="container">
    <h4 class="text-warning mb-3">Upload Existing Signpack <span data-bs-toggle="tooltip" title="Upload a ZIP file of a signpack you've already created" style="cursor: help; color: #0dcaf0; font-weight: bold;">?</span>
</h4>
    <form method="POST" action="/signpack/upload" enctype="multipart/form-data" class="mb-4">
      <div class="mb-3">
        <label for="signpackFile" class="form-label text-white">Upload .json or .zip Signpack</label>
        <input class="form-control" type="file" name="signpackFile" id="signpackFile" accept=".json,.zip" required />
      </div>
      <button class="btn btn-primary"><i class="fa fa-upload me-2"></i>Upload Signpack</button>
      <% if (selectedPack) { %>
        <a href="/signpack/multiblock/<%= selectedPack.pack_id %>" class="btn btn-outline-dark ms-2">
          <i class="fa fa-th me-1"></i> Create Multi-Block Sign <span data-bs-toggle="tooltip" title="Allows you to create multi-block signs." style="cursor: help; color: #0dcaf0; font-weight: bold;">?</span>

        </a>
      <% } %>
    </form>

   
    

    <form id="signpackForm"
  method="POST"
  enctype="multipart/form-data"
  action="<%= selectedSign ? ('/signpack/edit/' + selectedPack.pack_id + '/' + selectedSign.id) : ('/signpack/add-to-pack/' + (selectedPack ? selectedPack.pack_id : 'new')) %>">

      <div class="mb-4">
        <label class="form-label text-black">Select Signpack  <span data-bs-toggle="tooltip" title="Choose an existing pack to edit, or click “Create New” to start a new one." style="cursor: help; color: #0dcaf0; font-weight: bold;">?</span>
</label>
        <select class="form-select" onchange="location.href='/signpack?pack=' + this.value">
          <% signpacks.forEach(p => { %>
            <option value="<%= p.pack_id %>" <%= selectedPack?.pack_id === p.pack_id ? 'selected' : '' %>><%= p.name %></option>
          <% }) %>
          <option value="new" <%= !selectedPack ? 'selected' : '' %>>➕ Create New</option>
        </select>
      </div>

      <div class="mb-4">
        <label class="form-label text-black">Pack Name <span class="text-danger">*</span> <span data-bs-toggle="tooltip" title="What your Sign Pack will be called. This variable will be shown in-game." style="cursor: help; color: #0dcaf0; font-weight: bold;">?</span></label>
        <input class="form-control" name="packName" value="<%= selectedPack?.name || '' %>" required />
      </div>

      <% if (selectedPack && selectedPack.signs.length) { %>
        <div class="mb-4">
          <label class="form-label text-black">Edit Sign <span data-bs-toggle="tooltip" title="Choose a sign to edit, or select “New Sign” to add a new one." style="cursor: help; color: #0dcaf0; font-weight: bold;">?</span></label>
          <select class="form-select" onchange="updateSignIndex(parseInt(this.value) + 1)">


            <option value="">➕ New Sign</option>
            <% selectedPack.signs.forEach((s, i) => { %>
              <option value="<%= i %>" <%= selectedSign && selectedSign.name === s.name ? 'selected' : '' %>><%= s.name %></option>
            <% }) %>
          </select>
        </div>
      <% } %>

      <div class="mb-4">
        <label class="form-label text-black">Front Image <% if (!selectedSign || !selectedSign.front) { %><span class="text-danger">*</span><% } %> <span data-bs-toggle="tooltip" title="Refers to the Image for the front of this sign." style="cursor: help; color: #0dcaf0; font-weight: bold;">?</span></label>
        <input class="form-control" type="file" name="signs" accept="image/*"  <%= !selectedSign || !selectedSign.front ? 'required' : '' %>  />
        <% if (selectedSign && selectedSign.front && selectedPack) { %>
          <div class="mt-2">
            <strong class="text-secondary">Current: <span data-bs-toggle="tooltip" title="This is the current front image." style="cursor: help; color: #0dcaf0; font-weight: bold;">?</span></strong>
            <div class="mt-1">
              <img src="/users/<%= user.username %>/packs/<%= selectedPack.pack_id %>/<%= selectedSign.type %>/<%= selectedSign.front %>" style="width: 80px; cursor: pointer" class="border rounded shadow-sm" />
            </div>
          </div>
        <% } %>
      </div>

      <div class="mb-4">
        <label class="form-label text-black">Back Image <span data-bs-toggle="tooltip" title="Refers to the Image for the back of this sign. You Can select a exsisting one below." style="cursor: help; color: #0dcaf0; font-weight: bold;">?</span></label>
        <input class="form-control mb-2" type="file" name="back" accept="image/*" id="backImageInput" />
        <img id="backImagePreview" src="#" alt="Back Image Preview" style="width: 80px; display: none;" class="border rounded shadow-sm mt-2" />
        <% if (selectedSign && selectedSign.back) { %>
          <div class="mt-2">
            <strong class="text-secondary">Current Back: <span data-bs-toggle="tooltip" title="The current back being used." style="cursor: help; color: #0dcaf0; font-weight: bold;">?</span></strong>
            <div class="mt-1">
              <img
                src="/users/<%= user.username %>/packs/<%= selectedPack.pack_id %>/<%= selectedSign.type %>/<%= selectedSign.back %>"
                style="width: 80px; cursor: pointer"
                title="<%= selectedSign.back %>"
                class="border rounded shadow-sm"
              />
            </div>
          </div>
        <% } %>
        
        <% if (backImages?.length) { %>
          <div class="text-secondary">Or select existing:</div>
          <div class="d-flex flex-wrap gap-2">
            <% backImages.forEach(img => { %>
            

            <img
                src="<%= img.publicPath %>"
                data-bs-toggle="tooltip"
                data-bs-placement="top"
                title="<%= img.name %>"
                 data-back-preview="<%= img.name %>"
                class="border rounded shadow-sm back-image"
                style="width: 80px; cursor: pointer;"
                onclick="selectExistingBack('<%= img.publicPath %>', '<%= img.name %>')"

              />
            
            <% }) %>
            
          </div>
          <input type="hidden" name="existingBack" id="selectedBackImage" />
        <% } %>
      </div>
      
      <script>
        document.addEventListener('DOMContentLoaded', function () {
          const backImageInput = document.getElementById('backImageInput');
          const backImagePreview = document.getElementById('backImagePreview');
        
          if (backImageInput) {
            backImageInput.addEventListener('change', function (e) {
              const file = e.target.files[0];
              if (file) {
                const reader = new FileReader();
                reader.onload = function (event) {
                  backImagePreview.src = event.target.result;
                  backImagePreview.style.display = 'block';
                };
                reader.readAsDataURL(file);
              }
            });
          }
        });
        
        function selectExistingBack(path, filename) {
          // Set full path in hidden input (for backend to copy from)
          document.getElementById("selectedBackImage").value = path;
        
          // Remove current selection highlight
          document.querySelectorAll(".back-image").forEach(img =>
            img.classList.remove("selected")
          );
        
          // Apply .selected to the clicked image
          const selectedImg = document.querySelector(img[data-back-preview="${filename}"]);
          if (selectedImg) {
            selectedImg.classList.add("selected");
        
            // Update the preview image
            const preview = document.getElementById("backImagePreview");
            if (preview) {
              preview.src = selectedImg.src;
              preview.style.display = "block";
            }
          } else {
            console.warn("No match found for filename:", filename);
          }
        }
        
        
        
        
        
      </script>
      
      

      <div class="mb-4">
        <label class="form-label text-black">Sign Name <span class="text-danger">*</span> <span data-bs-toggle="tooltip" title="	Name of your sign. This is what will be presented in-game." style="cursor: help; color: #0dcaf0; font-weight: bold;">?</span></label>
        <input class="form-control" name="signstext" id="signText" required />
      </div>

     
      

      <div class="mb-4">
        <label class="form-label text-black">Sign Type Folder <% if (!selectedSign || !selectedSign.type) { %><span class="text-danger">*</span><% } %> <span data-bs-toggle="tooltip" title="What folder should the pack put this sign in (Done for you on export) example road_signs." style="cursor: help; color: #0dcaf0; font-weight: bold;">?</span></label>
        <input class="form-control mb-2" name="signtype_folder" id="signtype_folder"
          placeholder="e.g. useful_road" value="<%= selectedSign?.type || '' %>" list="folderList" <%= !selectedSign || !selectedSign.type ? 'required' : '' %> />
      </div>
      
      <div class="mb-4">
        <label class="form-label text-black">Sign Type Display Name <% if (!selectedSign || !selectedSign.type) { %><span class="text-danger">*</span><% } %> <span data-bs-toggle="tooltip" title="The Catagory name Example Road Signs." style="cursor: help; color: #0dcaf0; font-weight: bold;">?</span></label>
        <input class="form-control mb-2" name="signtype_label" id="signtype_label"
