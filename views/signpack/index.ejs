<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Signpack Maker | Traffic Control Mod</title>
  <link rel="icon" type="image/x-icon" href="https://gamearoo.top/ram-api-img/bc91c29e-d0af-460f-a30e-541cd5b57179.png" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="shortcut icon" href="/images/sign.png" type="image/png" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
  <link rel="stylesheet" href="/css/signpack.css" />
</head>
<style>
  #signList {
    display: grid;
    grid-template-columns: repeat(6, 64px);
    gap: 10px;
    justify-content: center;
    background-color: #1e1e1e; /* GUI panel bg */
    padding: 16px;
    border: 4px solid #555;
    border-radius: 8px;
    box-shadow: inset 0 0 8px rgba(0, 0, 0, 0.5);
  }
  
  .sign-entry {
    width: 64px;
    height: 64px;
    background: #2a2a2a;
    border: 2px solid #888;
    border-radius: 4px;
    box-shadow: 0 0 3px #000;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.1s ease;
    cursor: grab;
    position: relative;
  }
  
  .sign-entry img {
    max-width: 90%;
    max-height: 90%;
    image-rendering: pixelated;
  }
  
  .sign-entry.cutting {
    outline: 2px dashed #ff6ec7;
    background-color: rgba(255, 110, 199, 0.15);
  }
  
  .sign-entry.context-active {
    border-color: #ff6ec7;
  }
  
  #previewGridContainer {
    position: relative;
    display: inline-block;
    max-width: 100%;
    border: 2px dashed #ff6ec7;
    margin-top: 15px;
  }
  #previewGridImage {
    width: 100%;
    height: auto;
    display: block;
  }
  .grid-box {
    position: absolute;
    border: 1px solid rgba(255, 110, 199, 0.9);
    box-sizing: border-box;
    pointer-events: none;
  }

  #signList .sign-entry:hover {
    transform: scale(1.05);
    background-color: rgba(255, 255, 255, 0.1);
  }

  #signList .sign-entry img {
    width: 80px;
    height: auto;
    border-radius: 6px;
    margin-bottom: 5px;
  }

  .back-image.selected {
    border: 2px solid #007bff; /* Bootstrap primary color */
    box-shadow: 0 0 5px rgba(0, 123, 255, 0.5);
  }
</style>

<body>

  <script>
    function updateSignIndex(signIndex) {
      console.log(signIndex);
      const url = new URL(window.location.href);
      <% if (selectedPack) { %>
        url.searchParams.set('pack', '<%= selectedPack.pack_id %>');
      <% } %>
      if (signIndex !== "") {
        url.searchParams.set('signIndex', signIndex);
      } else {
        url.searchParams.delete('signIndex');
      }
      window.location.href = url.toString();
    }
  
    function downloadAndReload(packId) {
      const frame = document.getElementById("downloadFrame");
      frame.src = `/signpack/download/${packId}`;
  
      setTimeout(() => {
        if (confirm("Export complete. Would you like to remove this pack from the site now?")) {
          fetch(`/signpack/delete-pack/${packId}`, {
            method: "POST"
          })
          .then(res => res.json())
          .then(data => {
            if (data.success) {
              alert("Pack deleted.");
              location.href = "/signpack";
            } else {
              alert("Failed to delete pack.");
            }
          });
        } else {
          alert("Pack was not deleted and remains available.");
        }
      }, 3000);
    }

    function removeAndReload(packId) {
      
  
      setTimeout(() => {
        if (confirm("Are you sure you want to remove this pack from the site? This action cannot be undone.")) {
          fetch(`/signpack/delete-pack/${packId}`, {
            method: "POST"
          })
          .then(res => res.json())
          .then(data => {
            if (data.success) {
              alert("Pack deleted.");
              location.href = "/signpack";
            } else {
              alert("Failed to delete pack.");
            }
          });
        } else {
          alert("Pack was not deleted and remains available.");
        }
      }, 3000);
    }
  
    let textlineIndex = 0;
  
    function addTextline(data = {}) {
      const container = document.getElementById("textlinesContainer");
      const wrapper = document.createElement("div");
      wrapper.className = "border p-3 mb-3 rounded bg-dark text-white";
      wrapper.dataset.index = textlineIndex;
  
      wrapper.innerHTML = `
        <div class="d-flex justify-content-between align-items-center mb-2">
          <strong>Textline #${textlineIndex + 1}</strong>
          <button type="button" class="btn btn-sm btn-danger" onclick="this.closest('.border').remove()">Remove</button>
        </div>
        <div class="row g-2">
          <div class="col-md-4">
  <label class="form-label">
    Label <span class="text-danger">*</span>
    <span data-bs-toggle="tooltip" title="This text will display above the text field to tell the user what the purpose of the text field is" style="cursor: help; color: #0dcaf0; font-weight: bold;">?</span>
  </label>
  <input class="form-control" name="textlines[${textlineIndex}][label]" placeholder="Label" value="${data.label || ''}">
</div>

          <div class="col-md-2">
            <label class="form-label">
    X <span class="text-danger">*</span>
    <span data-bs-toggle="tooltip" title='The "x" coordinate of the sign to display your text' style="cursor: help; color: #0dcaf0; font-weight: bold;">?</span>
  </label>
            <input class="form-control" name="textlines[${textlineIndex}][x]" placeholder="X" value="${data.x || ''}" /></div>
          <div class="col-md-2">
              <label class="form-label">
    Y <span class="text-danger">*</span>
    <span data-bs-toggle="tooltip" title='The "y" coordinate of the sign to display your text' style="cursor: help; color: #0dcaf0; font-weight: bold;">?</span>
  </label>
            
            <input class="form-control" name="textlines[${textlineIndex}][y]" placeholder="Y" value="${data.y || ''}" /></div>
          <div class="col-md-2">
              <label class="form-label">
    Width <span class="text-danger">*</span>
    <span data-bs-toggle="tooltip" title='Determines the width of the text area on the sign' style="cursor: help; color: #0dcaf0; font-weight: bold;">?</span>
  </label>
            
            <input class="form-control" name="textlines[${textlineIndex}][width]" placeholder="Width" value="${data.width || ''}" /></div>
          <div class="col-md-2">
               <label class="form-label">
    Max Length 
    <span data-bs-toggle="tooltip" title='Determines the maximum amount of characters for this text line' style="cursor: help; color: #0dcaf0; font-weight: bold;">?</span>
  </label>
            <input class="form-control" name="textlines[${textlineIndex}][maxlength]" placeholder="Max" value="${data.maxlength || ''}" /></div>
          <div class="col-md-2">
              <label class="form-label">
    X Scale 
    <span data-bs-toggle="tooltip" title='How to scale the text on the x-axis. 1 is no scaling, < 1 is scale in, > 1 is scale out.' style="cursor: help; color: #0dcaf0; font-weight: bold;">?</span>
  </label>
            <input class="form-control" name="textlines[${textlineIndex}][xscale]" placeholder="X Scale" value="${data.xscale || ''}" /></div>
          <div class="col-md-2">
             <label class="form-label">
    Y Scale 
    <span data-bs-toggle="tooltip" title='How to scale the text on the y-axis. 1 is no scaling, < 1 is scale in, > 1 is scale out.' style="cursor: help; color: #0dcaf0; font-weight: bold;">?</span>
  </label>
            <input class="form-control" name="textlines[${textlineIndex}][yscale]" placeholder="Y Scale" value="${data.yscale || ''}" /></div>
          <div class="col-md-2">
              <label class="form-label">
    H Align
    <span data-bs-toggle="tooltip" title='Horizontal text alignment. Options are: left, center, right' style="cursor: help; color: #0dcaf0; font-weight: bold;">?</span>
  </label>
            <select class="form-control" name="textlines[${textlineIndex}][halign]">
  <option value="left" ${data.halign === 'left' ? 'selected' : ''}>Left</option>
  <option value="center" ${data.halign === 'center' ? 'selected' : ''}>Center</option>
  <option value="right" ${data.halign === 'right' ? 'selected' : ''}>Right</option>
</select> </div>
          <div class="col-md-2">
               <label class="form-label">
    Y Align
    <span data-bs-toggle="tooltip" title='Vertical text alignment. Options are: top, center, bottom' style="cursor: help; color: #0dcaf0; font-weight: bold;">?</span>
  </label>
            <select class="form-control" name="textlines[${textlineIndex}][valign]">
  <option value="top" ${data.valign === 'top' ? 'selected' : ''}>Top</option>
  <option value="center" ${data.valign === 'center' ? 'selected' : ''}>Center</option>
  <option value="bottom" ${data.valign === 'bottom' ? 'selected' : ''}>Bottom</option>
</select></div>
          <div class="col-md-2">
             <label class="form-label">
    Color
    <span data-bs-toggle="tooltip" title='The color of the text on the sign. This site will convert to int for you.' style="cursor: help; color: #0dcaf0; font-weight: bold;">?</span>
  </label>
            <input class="form-control form-control-color" type="color" name="textlines[${textlineIndex}][color]" value="${
              typeof data.color === 'number' ? '#' + data.color.toString(16).padStart(6, '0') : (data.color || '#000000')
            }" title="Text Color" />
          </div>
        </div>
      `;
      container.appendChild(wrapper);
      textlineIndex++;
    }
  
    function selectExistingBack(path, filename) {
      document.getElementById("selectedBackImage").value = path;
  
      document.querySelectorAll(".back-image").forEach(img =>
        img.classList.remove("selected")
      );
  
      const selectedImg = document.querySelector(`img[data-back-preview="${filename}"]`);
      if (selectedImg) {
        selectedImg.classList.add("selected");
  
        const preview = document.getElementById("backImagePreview");
        if (preview) {
          preview.src = selectedImg.src;
          preview.style.display = "block";
        }
      } else {
        console.warn("No match found for filename:", filename);
      }
    }
  
    function handleSignClick(entry) {
      if (!cutMode) return;
  
      const currentId = entry.dataset.id;
  
      if (cutSignIds.length === 0 || !entry.classList.contains("cutting")) {
        if (entry.classList.contains("cutting")) {
          entry.classList.remove("cutting");
          cutSignIds = cutSignIds.filter(id => id !== currentId);
        } else {
          entry.classList.add("cutting");
          cutSignIds.push(currentId);
        }
      } else {
        const container = document.getElementById("signList");
        const targetEl = container.querySelector(`[data-id='${currentId}']`);
  
        cutSignIds.forEach(id => {
          const cutEl = container.querySelector(`[data-id='${id}']`);
          if (cutEl) container.insertBefore(cutEl, targetEl);
        });
  
        cutSignIds = [];
        document.querySelectorAll(".sign-entry").forEach(el => el.classList.remove("cutting"));
      }
    }
  
    document.addEventListener("DOMContentLoaded", () => {
      document.querySelectorAll(".sign-entry").forEach(entry => {
        entry.addEventListener("click", () => handleSignClick(entry));
      });
  
      const signInput = document.querySelector('input[name="signs"]');
      if (signInput) {
        signInput.addEventListener('change', function (e) {
          const file = e.target.files[0];
          const signTextInput = document.getElementById('signText');
          if (signTextInput && !signTextInput.value.trim()) {
            let name = file.name.replace(/\.[^/.]+$/, '')
              .replace(/[_-]+/g, ' ')
              .replace(/([a-z])([A-Z])/g, '$1 $2')
              .replace(/\s+/g, ' ')
              .trim()
              .replace(/\b\w/g, l => l.toUpperCase());
            signTextInput.value = name;
          }
  
          const img = document.getElementById('previewSignImage');
          const reader = new FileReader();
          reader.onload = function (event) {
            img.src = event.target.result;
            img.style.display = 'block';
            img.onload = updateSignPreview;
          };
          reader.readAsDataURL(file);
        });
      }
  
      // Tooltip support
      const tooltipList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
      tooltipList.forEach(t => new bootstrap.Tooltip(t));
    });
  
    // Back image preview handler
    document.addEventListener('DOMContentLoaded', () => {
      const input = document.getElementById('backImageInput');
      const preview = document.getElementById('backImagePreview');
  
      if (input && preview) {
        input.addEventListener('change', e => {
          const file = e.target.files[0];
          if (!file) return;
  
          const reader = new FileReader();
          reader.onload = e => {
            preview.src = e.target.result;
            preview.style.display = 'block';
          };
          reader.readAsDataURL(file);
        });
      }
    });
  </script>

 <script>
  const tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
  tooltipTriggerList.map(el => new bootstrap.Tooltip(el))
</script>

  
  
  <% if (selectedSign) { %>
    <script>
      window.addEventListener("DOMContentLoaded", () => {
        const s = <%- JSON.stringify(selectedSign) %>;
        console.log("Loaded sign:", s);
  
        if (!s) return;
  
        let half = false;
        if (s.halfheight) half = true;
  
        document.getElementById("signText").value = s.name || '';
        document.getElementById("signtype_folder").value = s.type || '';
        document.getElementById("halfheight").checked = half;
        document.getElementById("signTool").value = s.tooltip || '';
  
        const container = document.getElementById("textlinesContainer");
        container.innerHTML = '';
        textlineIndex = 0;
  
        if (Array.isArray(s.textlines)) {
          s.textlines.forEach(line => addTextline(line));
        } else {
          console.warn("No textlines or not an array:", s.textlines);
        }
      });
    </script>
  <% } %>
