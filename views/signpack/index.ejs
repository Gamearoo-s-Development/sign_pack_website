          <a href="#" onclick="removeAndReload('<%= selectedPack.pack_id %>')" class="btn btn-danger">Delete Signpack <span data-bs-toggle="tooltip" title="Deletes the pack from the websites files (DANAGER this cant be undone)." style="cursor: help; color: #0dcaf0; font-weight: bold;">?</span></a>
