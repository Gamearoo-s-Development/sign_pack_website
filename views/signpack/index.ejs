            <% }) %>
          </select>
          </div>
        </div>
      <% } %>
      </div>
      </section>

      <section class="editor-card" id="section-images">
        <div class="editor-section-head">
          <span class="editor-section-num">3</span>
          <h3>Images</h3>
        </div>
        <div class="row g-4">
        <div class="col-md-6">
        <label class="form-label label-with-ram" for="frontImageInput">Front Image <% if (!selectedSign || !selectedSign.front) { %><span class="req-mark">*</span><% } %> <span data-bs-toggle="tooltip" title="Required sign field: front — PNG texture filename. Use square sizes (16×16, 32×32, …)." class="help-tip">?</span><% if (ramAiEnabled) { %><button type="button" class="btn-ram-ai-field" data-ram-ai-field="front" title="Ask Ram AI" aria-label="Ram AI explain front image"><i class="fa fa-wand-magic-sparkles"></i></button><% } %></label>
        <div class="editor-dropzone" data-editor-dropzone>
          <input class="editor-file-input" type="file" name="signs" id="frontImageInput" accept="image/png,.png" <%= !selectedSign || !selectedSign.front ? 'required' : '' %> />
          <div class="editor-dropzone-icon"><i class="fa fa-image"></i></div>
          <p class="editor-dropzone-title">Upload front image</p>
          <p class="editor-dropzone-hint">PNG, JPG, WEBP</p>
          <div class="editor-dropzone-actions">
            <button type="button" class="btn btn-sm editor-btn-accent-outline" data-dropzone-browse>Choose Image</button>
          </div>
          <span class="editor-dropzone-name" data-dropzone-name></span>
        </div>
        <% if (selectedSign && selectedSign.front && selectedPack) { %>
          <div class="mt-2">
            <strong class="text-secondary">Current: <span data-bs-toggle="tooltip" title="This is the current front image." class="help-tip">?</span></strong>
            <div class="mt-1">
              <img src="/users/<%= user.username %>/packs/<%= selectedPack.pack_id %>/<%= selectedSign.type %>/<%= selectedSign.front %>" style="width: 80px; cursor: pointer" class="border rounded shadow-sm" />
            </div>
          </div>
        <% } %>
        </div>

        <div class="col-md-6">
        <label class="form-label label-with-ram" for="backImageInput">Back Image <span data-bs-toggle="tooltip" title="Optional sign field: back — PNG filename; defaults to back.png if omitted. Reuse an existing back below or upload PNG." class="help-tip">?</span><% if (ramAiEnabled) { %><button type="button" class="btn-ram-ai-field" data-ram-ai-field="back" title="Ask Ram AI" aria-label="Ram AI explain back image"><i class="fa fa-wand-magic-sparkles"></i></button><% } %></label>
        <div class="editor-dropzone" data-editor-dropzone>
          <input class="editor-file-input" type="file" name="back" accept="image/png,.png" id="backImageInput" />
          <div class="editor-dropzone-icon"><i class="fa fa-image"></i></div>
          <p class="editor-dropzone-title">Upload back image</p>
          <p class="editor-dropzone-hint">PNG, JPG, WEBP — or pick existing below</p>
          <div class="editor-dropzone-actions">
            <button type="button" class="btn btn-sm editor-btn-accent-outline" data-dropzone-browse>Choose Image</button>
          </div>
          <span class="editor-dropzone-name" data-dropzone-name></span>
        </div>
        <img id="backImagePreview" src="#" alt="Back Image Preview" style="width: 80px; display: none;" class="border rounded shadow-sm mt-2" />
        <% if (selectedSign && selectedSign.back) { %>
          <div class="mt-2">
            <strong class="text-secondary">Current Back: <span data-bs-toggle="tooltip" title="The current back being used." class="help-tip">?</span></strong>
            <div class="mt-1">
              <img
                src="/users/<%= user.username %>/packs/<%= selectedPack.pack_id %>/<%= selectedSign.type %>/<%= selectedSign.back %>"
                style="width: 80px; cursor: pointer"
                title="<%= selectedSign.back %>"
                class="border rounded shadow-sm"
              />
            </div>
          </div>
        <% } %>
        
        <% if (backImages?.length) { %>
          <div class="text-secondary">Or select existing:</div>
          <div class="d-flex flex-wrap gap-2">
            <% backImages.forEach(img => { %>
            

            <img
                src="<%= img.publicPath %>"
                data-bs-toggle="tooltip"
                data-bs-placement="top"
                title="<%= img.name %>"
                 data-back-preview="<%= img.name %>"
                class="border rounded shadow-sm back-image"
                style="width: 80px; cursor: pointer;"
                onclick="selectExistingBack('<%= img.publicPath %>', '<%= img.name %>')"

              />
            
            <% }) %>
            
          </div>
          <input type="hidden" name="existingBack" id="selectedBackImage" />
        <% } %>
        </div>
        </div>
        <p class="editor-image-note mb-0"><i class="fa fa-circle-info"></i> Traffic Control expects <strong>PNG</strong> textures with <strong>square</strong> dimensions (e.g. 16×16, 32×32, 64×64).</p>
      </section>
      
      <script>
        document.addEventListener('DOMContentLoaded', function () {
          const backImageInput = document.getElementById('backImageInput');
          const backImagePreview = document.getElementById('backImagePreview');
        
          if (backImageInput) {
            backImageInput.addEventListener('change', function (e) {
              const file = e.target.files[0];
              if (file) {
                const reader = new FileReader();
                reader.onload = function (event) {
                  backImagePreview.src = event.target.result;
                  backImagePreview.style.display = 'block';
                };
                reader.readAsDataURL(file);
              }
            });
          }
        });
        
        function selectExistingBack(path, filename) {
          // Set full path in hidden input (for backend to copy from)
          document.getElementById("selectedBackImage").value = path;
        
          // Remove current selection highlight
          document.querySelectorAll(".back-image").forEach(img =>
            img.classList.remove("selected")
          );
        
          // Apply .selected to the clicked image
          const selectedImg = document.querySelector(img[data-back-preview="${filename}"]);
          if (selectedImg) {
            selectedImg.classList.add("selected");
        
            // Update the preview image
            const preview = document.getElementById("backImagePreview");
            if (preview) {
              preview.src = selectedImg.src;
              preview.style.display = "block";
            }
          } else {
            console.warn("No match found for filename:", filename);
          }
        }
        
        
        
        
        
      </script>

      <section class="editor-card" id="section-sign-fields">
