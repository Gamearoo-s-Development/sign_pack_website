<script>
  // Preview logic for textlines
  function updateSignPreview() {
    const container = document.getElementById('signPreviewContainer');
    const previewImage = document.getElementById('previewSignImage');
    if (!previewImage || !previewImage.src || previewImage.src === '#' || !previewImage.complete) return;
  
    container.querySelectorAll('.preview-textline').forEach(e => e.remove());
  
    const imgWidth = previewImage.clientWidth;
    const imgHeight = previewImage.clientHeight;
  
    const FONT_HEIGHT = 10;
    const previewSize = Math.min(imgWidth, imgHeight);
    const fullScale = previewSize / (FONT_HEIGHT * 16);
    const fontHeightScaled = FONT_HEIGHT * fullScale;
  
    const textlineWrappers = document.querySelectorAll('#textlinesContainer > .border');
  
    textlineWrappers.forEach((wrapper, idx) => {
      const x = parseFloat(wrapper.querySelector('[name$="[x]"]').value) || 0;
      const y = parseFloat(wrapper.querySelector('[name$="[y]"]').value) || 0;
      const label = wrapper.querySelector('[name$="[label]"]').value || `Line ${idx + 1}`;
      const color = wrapper.querySelector('[name$="[color]"]').value || '#ff0000';
      const xscale = parseFloat(wrapper.querySelector('[name$="[xscale]"]').value) || 1;
      const yscale = parseFloat(wrapper.querySelector('[name$="[yscale]"]').value) || 1;
      const width = parseFloat(wrapper.querySelector('[name$="[width]"]').value) || 1;
      const maxlength = parseInt(wrapper.querySelector('[name$="[maxlength]"]').value) || null;
      const halign = (wrapper.querySelector('[name$="[halign]"]').value || 'left').toLowerCase();
      const valign = (wrapper.querySelector('[name$="[valign]"]').value || 'top').toLowerCase();
  
      const effectiveLabel = maxlength ? label.substring(0, maxlength) : label;
  
      const posX = x * fontHeightScaled;
      const posY = y * fontHeightScaled;
  
      const boxWidth = width * fontHeightScaled;
      const boxHeight = FONT_HEIGHT * yscale * fullScale;
  
      let offsetX = 0;
      if (halign === 'center') offsetX = -boxWidth / 2;
      else if (halign === 'right') offsetX = -boxWidth;
  
      let offsetY = 0;
      if (valign === 'center') offsetY = -boxHeight / 2;
      else if (valign === 'bottom') offsetY = -boxHeight;
  
      const bg = document.createElement('div');
      bg.className = 'preview-textline';
      bg.style.position = 'absolute';
      bg.style.left = `${previewImage.offsetLeft + posX}px`;
      bg.style.top = `${previewImage.offsetTop + posY}px`;
      bg.style.width = `${boxWidth}px`;
      bg.style.height = `${boxHeight}px`;
      bg.style.transform = `translate(${offsetX}px, ${offsetY}px)`;
      bg.style.backgroundColor = 'rgba(0,255,0,0.75)';
      bg.style.pointerEvents = 'none';
      container.appendChild(bg);
  
      const text = document.createElement('div');
      text.className = 'preview-textline';
      text.innerText = effectiveLabel;
      text.style.position = 'absolute';
      text.style.left = `${previewImage.offsetLeft + posX}px`;
      text.style.top = `${previewImage.offsetTop + posY}px`;
      text.style.transform = `translate(${offsetX}px, ${offsetY}px) scale(${xscale}, ${yscale})`;
      text.style.color = color;
      text.style.fontWeight = 'bold';
      text.style.whiteSpace = 'nowrap';
      text.style.textAlign = 'center';
      text.style.width = `${boxWidth}px`;
      text.style.height = `${boxHeight}px`;
      text.style.display = 'flex';
      text.style.alignItems = 'center';
      text.style.justifyContent = 'center';
      text.style.pointerEvents = 'none';
      text.style.textShadow = '1px 1px 2px black';
  
      container.appendChild(text);
    });
  }
  


  
  
  // Listen to input changes in textlinesContainer
  document.getElementById('textlinesContainer').addEventListener('input', updateSignPreview);

  // Listen for image changes
  document.querySelector('input[name="signs"]').addEventListener('change', function (e) {
    const file = e.target.files[0];
    const reader = new FileReader();
  
    if (!file) return;
  
    // 🎯 Convert filename into nice-looking title
    const signTextInput = document.getElementById('signText');
    if (signTextInput && !signTextInput.value.trim()) {
      let name = file.name.replace(/\.[^/.]+$/, ''); // remove extension
      name = name
        .replace(/[_-]+/g, ' ')                // underscores/dashes → space
        .replace(/([a-z])([A-Z])/g, '$1 $2')   // camelCase → spaced
        .replace(/\s+/g, ' ')                  // normalize spaces
        .trim()
        .replace(/\b\w/g, l => l.toUpperCase()); // capitalize each word
  
      signTextInput.value = name;
    }
  
  

    reader.onload = function (event) {
      const img = document.getElementById('previewSignImage');
      img.src = event.target.result;
      img.style.display = 'block';
      img.onload = updateSignPreview;
    };
  
    reader.readAsDataURL(file);
  });

  // Initialize preview on load
  window.addEventListener('DOMContentLoaded', () => {
    setTimeout(updateSignPreview, 200); // ensures correct sizing
  });
</script>




