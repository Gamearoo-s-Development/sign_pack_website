  <main class="site-main">
    <section class="site-hero">
      <div class="container">
        <div class="glass mx-auto p-4 p-md-5">
          <h1 class="display-4 fw-bold text-warning mb-3">Signpack Maker</h1>
          <p class="lead subtle mb-4">
            Create and manage custom <strong>signpacks</strong> for the
            <strong>Traffic Control Mod</strong> — in your browser or with the portable Windows app.
          </p>
          <div class="d-flex flex-column flex-sm-row gap-3 justify-content-center flex-wrap">
            <a href="/app" class="btn btn-warning btn-lg">Download App</a>
            <a href="/login" class="btn btn-outline-light btn-lg">Open Web Editor</a>
            <a href="#" data-signpack-github class="btn btn-outline-light btn-lg">View on GitHub</a>
          </div>
          <p class="mt-4 mb-0">
            <a href="/login" class="btn btn-sm btn-warning">Login to Start</a>
          </p>
        </div>
      </div>
    </section>

    <section class="site-section container">
      <h2 class="text-center mb-4">What you can do</h2>
      <div class="row g-4">
        <div class="col-md-6 col-lg-3">
          <div class="card glass feature-card bg-transparent text-light p-3">
            <div class="fs-4 mb-2">➕</div>
            <h5 class="text-warning">Upload signs</h5>
            <p class="subtle small mb-0">Add your own sign images to a pack.</p>
          </div>
        </div>
        <div class="col-md-6 col-lg-3">
          <div class="card glass feature-card bg-transparent text-light p-3">
            <div class="fs-4 mb-2">🛠️</div>
            <h5 class="text-warning">Edit packs</h5>
            <p class="subtle small mb-0">Modify existing signpack ZIPs.</p>
          </div>
        </div>
        <div class="col-md-6 col-lg-3">
          <div class="card glass feature-card bg-transparent text-light p-3">
            <div class="fs-4 mb-2">✏️</div>
            <h5 class="text-warning">Text lines</h5>
            <p class="subtle small mb-0">Manage textlines and formatting.</p>
          </div>
        </div>
        <div class="col-md-6 col-lg-3">
          <div class="card glass feature-card bg-transparent text-light p-3">
            <div class="fs-4 mb-2">📦</div>
            <h5 class="text-warning">Export ZIP</h5>
            <p class="subtle small mb-0">Export a ready-to-use signpack.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="site-section container">
      <h2 class="text-center mb-4">Ram AI Helper <span class="badge bg-secondary fs-6 align-middle">Optional</span></h2>
      <p class="text-center subtle mx-auto mb-4" style="max-width: 42rem;">
        A built-in assistant for Traffic Control signpacks. Use it when you want help — upload, save, and export work the same without it.
      </p>
      <div class="row g-3 mb-4">
        <div class="col-md-6 col-lg-3">
          <div class="card glass bg-transparent text-light p-3 h-100">
            <div class="text-warning mb-2"><i class="fa fa-circle-check"></i></div>
            <h5 class="text-warning h6">Optional</h5>
            <p class="subtle small mb-0">Works only when you open the assistant — never required to edit signpacks.</p>
          </div>
        </div>
        <div class="col-md-6 col-lg-3">
          <div class="card glass bg-transparent text-light p-3 h-100">
            <div class="text-warning mb-2"><i class="fa fa-shield-halved"></i></div>
            <h5 class="text-warning h6">Secure by design</h5>
            <p class="subtle small mb-0">Requests are handled safely through Signpack Maker — not exposed in your browser.</p>
          </div>
        </div>
        <div class="col-md-6 col-lg-3">
          <div class="card glass bg-transparent text-light p-3 h-100">
            <div class="text-warning mb-2"><i class="fa fa-hourglass-half"></i></div>
            <h5 class="text-warning h6">Queue-aware</h5>
            <p class="subtle small mb-0">See live status while Ram AI works — keep editing while you wait.</p>
          </div>
        </div>
        <div class="col-md-6 col-lg-3">
          <div class="card glass bg-transparent text-light p-3 h-100">
            <div class="text-warning mb-2"><i class="fa fa-lightbulb"></i></div>
            <h5 class="text-warning h6">You're in control</h5>
            <p class="subtle small mb-0">Suggestions are advisory — you decide what to apply to your pack.</p>
          </div>
        </div>
      </div>
      <div class="text-center">
        <a href="/help/ram-ai.html" class="btn btn-outline-warning btn-sm me-2">Learn more</a>
        <a href="/login" class="btn btn-warning btn-sm">Try in editor</a>
